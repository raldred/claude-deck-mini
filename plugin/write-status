#!/usr/bin/python3
"""Claude Code hook for Claude Deck Mini.

Reads a hook event on stdin and records the session's status under
~/.claude-deck/status/<session-id>.json, which the menu bar app watches.
Self-contained (stdlib only) so it runs from Claude Code's plugin cache with
no dependency on the app bundle. Never blocks or fails Claude: all errors are
swallowed and the process exits 0.

Subagents (forked/background agents) are handled separately. Their hooks carry
an `agent_id` and run under their own `session_id`, but their `Stop` is
auto-converted to `SubagentStop`. Rather than give each subagent its own key,
we track them in ~/.claude-deck/subagents/<agent_id>.json keyed to the parent
session (parsed from the transcript path) so the app can badge the parent.

Every record carries the owning Claude process pid so the app can reap files
whose process has died (SessionEnd is not crash-safe).

Mirrors HookEventName.status / HookCommand in the Swift app.
"""

import json
import os
import subprocess
import sys
import tempfile
from datetime import datetime, timezone

WORKING = {"SessionStart", "UserPromptSubmit", "PreToolUse", "PostToolUse"}
WAITING = {"Stop", "Notification", "PermissionRequest"}
FINISHED = {"SessionEnd"}
SUBAGENT_START = {"SubagentStart", "UserPromptSubmit", "PreToolUse", "PostToolUse"}
SUBAGENT_STOP = {"SubagentStop"}


def _status_dir():
    return os.path.join(os.path.expanduser("~"), ".claude-deck", "status")


def _subagent_dir():
    return os.path.join(os.path.expanduser("~"), ".claude-deck", "subagents")


def _status_for(event):
    if event in WORKING:
        return "working"
    if event in WAITING:
        return "waiting"
    if event in FINISHED:
        return "finished"
    return None


def _claude_pid():
    """The nearest `claude` process above this hook.

    Hooks run under a shell (`sh -c` / zsh), so os.getppid() is that shell, not
    Claude. Walk the ancestry until a process whose command contains "claude",
    which is the stable, long-lived session process the app can probe for
    liveness. Falls back to getppid() if the walk finds nothing.
    """
    override = os.environ.get("CLAUDE_DECK_PID_OVERRIDE")
    if override:
        try:
            return int(override)
        except ValueError:
            pass
    try:
        pid = os.getppid()
        for _ in range(10):
            out = subprocess.run(
                ["ps", "-o", "ppid=,comm=", "-p", str(pid)],
                capture_output=True, text=True, timeout=2).stdout.strip()
            if not out:
                break
            parts = out.split(None, 1)
            ppid = int(parts[0])
            comm = parts[1] if len(parts) > 1 else ""
            if "claude" in comm.lower():
                return pid
            if ppid in (0, 1, pid):
                break
            pid = ppid
    except Exception:
        pass
    return os.getppid()


def _write_json(path, record):
    d = os.path.dirname(path)
    os.makedirs(d, exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=d, suffix=".tmp")
    try:
        with os.fdopen(fd, "w") as f:
            json.dump(record, f)
        os.replace(tmp, path)  # atomic
    except Exception:
        try:
            os.remove(tmp)
        except OSError:
            pass
        raise


def _remove(path):
    try:
        os.remove(path)
    except FileNotFoundError:
        pass


def _now():
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def _has_real_transcript(payload):
    """A real session has a non-empty .jsonl transcript. Pre-warmed spares fire
    warmup hooks with a session_id but no transcript yet, so gating on this keeps
    them off the deck until they become real conversations. If transcript_path is
    absent we can't tell — return True (best-effort: never hide a real session)."""
    transcript = payload.get("transcript_path")
    if not transcript:
        return True
    try:
        return os.path.getsize(transcript) > 0
    except OSError:
        return False


def _handle_subagent(payload, agent_id, event):
    """Subagent hooks manage a sidecar keyed by agent_id, tied to the parent
    session via the transcript filename. Never writes a top-level status file."""
    path = os.path.join(_subagent_dir(), f"{agent_id}.json")
    if event in SUBAGENT_STOP:
        _remove(path)
        return
    if event not in SUBAGENT_START:
        return
    # The parent session id is the subagent's transcript filename: subagents
    # write into the parent's transcript. If transcript_path is ever absent the
    # sidecar still gets written (and pid-reaped later) but with parentId=None,
    # so the parent's badge just won't count it.
    transcript = payload.get("transcript_path") or ""
    parent_id = os.path.splitext(os.path.basename(transcript))[0] or None
    _write_json(path, {
        "agentId": agent_id,
        "parentId": parent_id,
        "pid": _claude_pid(),
        "timestamp": _now(),
    })


def handle(payload):
    session_id = payload.get("session_id")
    event = payload.get("hook_event_name")
    if event is None:
        return

    # A subagent invocation carries agent_id; track it separately from sessions.
    agent_id = payload.get("agent_id")
    if agent_id:
        _handle_subagent(payload, agent_id, event)
        return

    if not session_id:
        return
    status = _status_for(event)
    if status is None:
        return

    path = os.path.join(_status_dir(), f"{session_id}.json")
    if status == "finished":
        _remove(path)
        return

    if not _has_real_transcript(payload):
        return

    _write_json(path, {
        "sessionId": session_id,
        "status": status,
        "cwd": payload.get("cwd"),
        "pid": _claude_pid(),
        "timestamp": _now(),
    })


def main():
    try:
        data = sys.stdin.read()
        if data.strip():
            handle(json.loads(data))
    except Exception:
        pass  # never fail the hook
    sys.exit(0)


if __name__ == "__main__":
    main()
